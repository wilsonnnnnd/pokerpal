{
  "expo": {
    "name": "iPokerpal",
    "slug": "pokerpal", 
    "version": "1.1.3",
    "scheme": "pokerpal",
    "orientation": "portrait",
    "icon": "./src/assets/PokerPal.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./src/assets/Loading_PokerPal.png",
      "resizeMode": "contain",
      "backgroundColor": "#fcf5e7"
    },
    "ios": {
      "usesAppleSignIn": true,
      "supportsTablet": true,
      "bundleIdentifier": "com.wilsonnnnd.pokerpal.dev",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/PokerPal.png",
        "backgroundColor": "#fcf5e7"
      },
      "package": "com.wilsonnnnd.pokerpal.dev",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "plugins": [
      [
        "expo-apple-authentication"
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.366251048350-btru5udsrj4g35aqo8u39a9i97e62rmd"
        }
      ],
      "expo-sqlite",
      "expo-audio"
    ],
    "web": {
      "favicon": "./src/assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "ee93057e-27d6-41c7-b9ae-d494fd7663c2"
      }
    },
    "owner": "hd-software",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/ee93057e-27d6-41c7-b9ae-d494fd7663c2"
    }
  }
}
